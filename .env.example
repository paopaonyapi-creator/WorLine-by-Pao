# =============================================================================
# Unifilar Studio — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your real values:
#   cp .env.example .env.local
#
# For Railway deployment, add these in the Railway Dashboard → Variables tab.
# =============================================================================

# --------------- Supabase ---------------
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Direct DB connection (for migrations only — NOT used at runtime)
DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# --------------- Stripe ---------------
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Create a webhook in Stripe Dashboard → Developers → Webhooks
# Endpoint URL: https://your-domain.com/api/stripe/webhook
# Events: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=whsec_...

# Create a product + price in Stripe Dashboard → Products
# Copy the Price ID (starts with price_)
STRIPE_PRO_PRICE_ID=price_...

# --------------- App ---------------
# Your production URL (Railway will generate this)
NEXT_PUBLIC_APP_URL=https://your-app.up.railway.app
